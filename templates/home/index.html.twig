{% extends 'base.html.twig' %}

{% block title %}Hello HomeController!{% endblock %}

{% block body %}

<!--section Hero--> 
<section class="hero-section text-white d-flex align-items-center">
    <div class="container text-center py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <img src="{{ asset('images/logoBlc.png') }}" alt="Logo Nid'Help">
                <h1 class="display-3 fw-bold mb-3 mt-5">Bienvenue sur <span class="text-white">Nid'Help</span></h1>
                <p class="lead mb-5 opacity-90">
                    La plateforme solidaire d'entraide entre voisins. 
                    Besoin d'un coup de main ou envie d'aider ? Vous êtes au bon endroit.
                </p>
                <div class="d-flex justify-content-center gap-3 mb-5">
                    
                    <twig:BootstrapButton 
                        text="Découvrir les services" 
                        type="primary" 
                        link="{{ path('app_service_index') }}" 
                    />
                    {% if app.user %}
                    <twig:BootstrapButton 
                        text="Proposer mon aide" 
                        type="light" 
                        link="{{ path('app_service_create') }}" 
                        :outlined="true"
                    />
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>

<section class="container py-3">
    <div class="row g-4 py-5 row-cols-1 row-cols-lg-3 text-center">
        <div class="col">
            <div class="card h-100 shadow-sm p-3 border-0"> 
                <h2 class="fs-4 text-primary">Confiance</h2>
                <p>Une communauté de voisins vérifiés pour une entraide en toute sécurité.</p>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm p-3 border-0">            
                <h2 class="fs-4 text-primary">Solidarité</h2>
                <p>Renforcez les liens dans votre quartier en rendant service simplement.</p>
            </div>
        </div>

        <div class="col">
            <div class="card h-100 shadow-sm p-3 border-0">
                <h2 class="fs-4 text-primary">Rapidité</h2>
                <p>Trouvez une solution à votre problème à deux pas de chez vous.</p>
            </div>
        </div>
</section>

<!--Section dernières prestations-->
<section class="container py-4">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold">Dernières prestations</h2>
            <p class="text-muted">Découvrez les derniers services mis en ligne.</p>
        </div>
        <div>
            <twig:BootstrapButton 
                text="Tous nos services"
                type="primary" 
                link="{{ path('app_service_index')}}" 
                outlined
            />
        </div>
    </div>

    <div class="row g-4">
        {% for service in lastServices %}
            <div class="col-12 col-md-4">
                <twig:BootstrapCard 
                    name="{{ service.name }}"
                    description="{{ service.description|excerpt(100) }}"
                    img="{{ service.category and service.category.picture ? asset('uploads/categories/' ~ service.category.picture) : '' }}" 
                    :actions="[
                        { label: 'Détails', link: path('app_service_show', { id: service.id }), type: 'outline-primary' }
                    ]"
                />
            </div>
        {% else %}
            <p class="text-center">Aucun service n'a encore été ajouté.</p>
        {% endfor %}
    </div>
</section>

<!--Section toutes les catégories-->
<section class="container py-4">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h2 class="fw-bold">Toutes nos catégories</h2>            
        </div>            
    </div>

    <div class="row g-4">
        {% for category in categories %}
            <div class="col-12 col-md-3">
                <twig:BootstrapCard 
                    name="{{ category.name }}"
                    description=""
                    img="{{ category.picture ? asset('uploads/categories/' ~ category.picture) : '' }}"
                    :actions="[
                        { label: 'Voir la catégorie', link: '#', type: 'outline-primary' }
                    ]"
                />
            </div>
        {% else %}
            <p class="text-center">Aucune catégorie n'a encore été ajoutée.</p>
        {% endfor %}
    </div>



</section>

{% endblock %}
