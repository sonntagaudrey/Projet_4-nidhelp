{# templates/exchange/contact.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Contacter le prestataire{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row">
        {# GAUCHE #}
        <div class="col-md-4 mb-4">
            <div class="card border-0 bg-light shadow-sm">
                <div class="card-body text-center">
                    <div class="mb-3">                        
                        <i class="bi bi-person-circle display-1 text-primary"></i>
                    </div>
                    <h4 class="card-title">{{ service.author.firstname }} {{ service.author.name }}</h4>
                    <p class="text-muted">Prestataire NidHelp</p>
                    <hr>
                    <div class="text-start">
                        <p><strong><i class="bi bi-envelope me-2"></i> Email :</strong></p>
                        <p>{{ service.author.email }}</p> 
                        
                        <p><strong><i class="bi bi-telephone me-2"></i> Téléphone :</strong></p>
                        <p>{{ service.author.phone }}</p>
                        
                        <p><strong><i class="bi bi-geo-alt me-2"></i> Localisation :</strong></p>
                        <p>{{ service.author.postcode }} {{ service.author.town }}</p>
                    </div>
                </div>
            </div>
        </div>

        {# DROITE #}
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h3 class="card-title mb-0">Envoyer un message pour : {{ service.name }}</h3>
                </div>
                <div class="card-body">
                    {{ form_start(contactForm) }}
                        <div class="mb-3">
                            {{ form_label(contactForm.object) }}
                            {{ form_widget(contactForm.object) }}
                            {{ form_errors(contactForm.object) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(contactForm.message) }}
                            {{ form_widget(contactForm.message) }}
                            {{ form_errors(contactForm.message) }}
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="{{ path('app_service_show', {'id': service.id}) }}" class="btn btn-outline-primary me-md-2">Annuler</a>
                            <button type="submit" class="btn btn-primary px-4">Envoyer le message</button>
                        </div>
                    {{ form_end(contactForm) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}