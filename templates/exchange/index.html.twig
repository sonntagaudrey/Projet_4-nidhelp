{% extends 'base.html.twig' %}

{% block title %}Mes contacts - Nid'Help{% endblock %}

{% block body %}
<div class="mt-3">
    {% include '_partials/flashes.html.twig' %}
</div>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 fw-bold">Mes Messages et Contacts</h1>
        <a href="{{ path('app_dashboard') }}" class="btn btn-outline-primary">Retour au Dashboard</a>
    </div>

    {% if exchanges is empty %}
        <div class="alert alert-info shadow-sm">
            <i class="fas fa-info-circle"></i> Vous n'avez pas encore d'échanges ou de contacts.
        </div>
    {% else %}
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th>Date</th>
                            <th>Service concerné</th>
                            <th>Interlocuteur</th>
                            <th>Dernier message</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for exchange in exchanges %}
                            {% set isSender = (exchange.sender == app.user) %}
                            {% set contact = isSender ? exchange.receiver : exchange.sender %}
                            
                            <tr>
                                <td class="text-muted small">
                                    {{ exchange.createDate|date('d/m/Y H:i') }}
                                </td>
                                <td>
                                    <span class="badge bg-primary text-white">{{ exchange.service.name }}</span>
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        
                                        <div>
                                            <small class="text-muted">{{ isSender ? 'Envoyé à' : 'Reçu de' }}</small>
                                            <p class="fw-bold">{{ contact.firstname }} {{ contact.name }}</p>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <p class="mb-0 text-truncate" style="max-width: 250px;">
                                        {{ exchange.message }}...
                                    </p>                                    
                                </td>
                                <td class="text-end">
                                    <a href="{{ path('app_service_show', {'id': exchange.service.id}) }}" class="btn btn-sm btn-outline-primary border" title="Voir l'annonce">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="{{ path('app_exchange_reply', {'id': exchange.id}) }}" class="btn btn-sm btn-primary">
                                        <i class="bi bi-reply"></i> Répondre
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}
</div>

{% endblock %}