{% extends 'base.html.twig' %}

{% block title %}{{ service.name }} - Nid'Help{% endblock %}

{% block body %}
<div class="mt-3">
    {% include '_partials/flashes.html.twig' %}
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h2 fw-bold text-dark">Détails de la prestation</h1>
                <twig:BootstrapButton 
                    text="Retour à la liste"
                    type="primary" 
                    link="{{ path('app_service_index')}}" 
                    outlined
                />
            </div>

            <div class="card shadow-sm border-0 overflow-hidden">

                {% if service.category and service.category.picture %}
                    <img src="{{ asset('uploads/categories/' ~ service.category.picture) }}" 
                         alt="{{ service.category.name }}" 
                         class="card-img-top">
                {% else %}
                    <div class="bg-light d-flex align-items-center justify-content-center" style="height: 250px;">
                        <div class="text-muted text-center">
                            <span class="d-block mb-2 fs-1">🛠️</span>
                            <span>Aucune image disponible</span>
                        </div>
                    </div>
                {% endif %}

                <div class="card-body p-4 p-md-5">

                    {% if service.category %}
                        <span class="badge bg-primary mb-3 px-3 py-2 rounded-pill">
                            {{ service.category.name }}
                        </span>
                    {% endif %}
                    
                    <h2 class="card-title h3 fw-bold mb-4">{{ service.name }}</h2>
                    
                    <h5 class="text-muted fs-6 text-uppercase mb-2">Description</h5>
                    <p class="card-text text-secondary lh-lg mb-4">
                        {{ service.description|nl2br }}
                    </p>

                    <hr class="my-4 text-muted">
                    <div class="author-info p-3 border rounded bg-light mb-4">
                        <h5 class="mb-2">Proposé par :</h5>
                        <p class="mb-3">
                            <strong>{{ service.author.firstname }} {{ service.author.name }}</strong>
                        </p>
                        <p class="mb-3">
                            <strong>Localisation :</strong> {{ service.author.postcode }} {{ service.author.town }}
                        </p>
                        
                       
                        {% if app.user %}
                            {% if app.user != service.author %}
                                <a href="{{ path('app_service_contact', {'id': service.id}) }}" class="btn btn-primary">
                                    <i class="fas fa-envelope"></i> Contacter le prestataire
                                </a>
                            {% endif %}
                        {% else %}
                            <a href="{{ path('app_login') }}" class="btn btn-outline-primary">
                                <i class="fas fa-lock"></i> Connectez-vous pour contacter le prestataire
                            </a>
                        {% endif %}
                    </div>

                    
                    {% if app.user == service.author %}
                        <div class="d-flex justify-content-end gap-2">
                            <twig:BootstrapButton 
                                text="Modifier ce service"
                                type="primary" 
                                link="{{ path('app_service_update', {'id': service.id}) }}" 
                            />
                            <form method="post" action="{{ path('app_service_delete', {'id': service.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer votre prestation ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ service.id) }}">
                                <button type="submit" class="btn btn-danger">
                                    Supprimer ce service
                                </button>
                            </form>
                        </div>
                    {% endif %}
                    
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}