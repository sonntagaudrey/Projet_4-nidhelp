{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            
            <h1 class="h3 mb-3 fw-normal text-center">Réinitialisation</h1>

            {% for flash_error in app.flashes('reset_password_error') %}
                <div class="alert alert-danger">{{ flash_error }}</div>
            {% endfor %}

            <div class="border rounded p-4 bg-light shadow-sm">
                {{ form_start(requestForm) }}
                    <div class="mb-3">
                        {{ form_label(requestForm.email, 'Votre e-mail') }}
                        {{ form_widget(requestForm.email, {'attr': {'class': 'form-control'}}) }}
                        <div class="form-text">
                            Nous vous enverrons un lien de récupération.
                        </div>
                    </div>

                    <button class="btn btn-primary w-100" type="submit">
                        Envoyer l'e-mail
                    </button>
                {{ form_end(requestForm) }}
            </div>

            <p class="mt-3 text-center">
                <a href="{{ path('app_login') }}">Retour</a>
            </p>

        </div>
    </div>
</div>
{% endblock %}