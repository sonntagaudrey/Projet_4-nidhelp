{% extends 'base.html.twig' %}

{% block title %}Mon Tableau de Bord - Nid'Help{% endblock %}

{% block body %}
<div class="mt-3">
    {% include '_partials/flashes.html.twig' %}
</div>

<section class="container py-5">
    
    {# En-tête du Dashboard #}
    <div class="row mb-5">
        <div class="col-12">
            <h1 class="h2 fw-bold text-dark">Mon Tableau de Bord</h1>
            <p class="text-muted">Bienvenue dans votre espace personnel, {{ app.user.firstname }}</p>
        </div>
    </div>

    <div class="row g-4">
        
        <!-- GAUCHE -->
        <div class="col-12 col-lg-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h2 class="h5 fw-bold">Mes Informations</h2>
                </div>
                <div class="card-body">
                    
                    <ul class="list-unstyled text-secondary mb-4 lh-lg">        
                        <li><strong>Adresse Email :</strong><br> {{ app.user.email }}</li>
                        <li><strong>Rôle :</strong><br> {{ 'ROLE_ADMIN' in app.user.roles ? 'Administrateur' : 'Utilisateur' }}</li>
                    </ul>

                    <div class="d-grid"> 
                        <twig:BootstrapButton 
                            text="Modifier mes informations"
                            type="primary" 
                            link="#" 
                            outlined
                        />                           
                    </div>
                    
                </div>
            </div>
        </div>

       <!-- DROITE -->
        <div class="col-12 col-lg-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                    <h2 class="h5 fw-bold">Mes Services Proposés</h2>
                    <a href="{{ path('app_category_create') }}" class="btn btn-primary btn-sm">Nouveau service</a>
                </div>
                
                <div class="card-body">

                    {% if app.user.services is defined and app.user.services is not empty %}
                        
                        <div class="row g-3">
                            {% for service in app.user.services %}
                                <div class="col-12 col-md-6">
                                    <div class="card h-100 shadow-sm border-0">

                                        {% set imagePath = service.category and service.category.picture ? asset('uploads/categories/' ~ service.category.picture) : '' %}
                                        {% if imagePath %}
                                            <img src="{{ imagePath }}" class="card-img-top" alt="{{ service.name }}" style="height: 200px; object-fit: cover;">
                                        {% endif %}

                                        <div class="card-body">
                                            <h5 class="card-title fw-bold">{{ service.name }}</h5>
                                            <p class="card-text text-muted">
                                                {{ service.description|excerpt(50) }}
                                            </p>
                                        </div>

                                        <div class="card-footer bg-transparent border-0 d-flex justify-content-start gap-2 pb-3 px-3">

                                            <a href="{{ path('app_service_show', { id: service.id }) }}" class="btn btn-outline-primary btn-sm">
                                                Détails
                                            </a>

                                            <a href="{{ path('app_service_update', { id: service.id }) }}" class="btn btn-primary btn-sm">
                                                Modifier
                                            </a>

                                            <form method="post" action="{{ path('app_service_delete', { id: service.id }) }}" onsubmit="return confirm('Êtes-vous sur de vouloir supprimer votre prestation ?');" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ service.id) }}">
                                                <button type="submit" class="btn btn-danger btn-sm">
                                                    Supprimer
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                              
                        </div>

                    {% else %}

                        <div class="text-center py-5 text-muted">                            
                            <h5 class="fw-bold">Vous ne proposez aucun service</h5>
                            <p>Commencez à générer des revenus en proposant vos compétences.</p>

                            <twig:BootstrapButton 
                                text="Créer mon premier service"
                                type="primary" 
                                link="{{ path('app_service_create') }}" 
                                outlined
                            /> 
                            
                        </div>
                    {% endif %}

                </div>
            </div>
        </div>

    </div>
</section>

<!-- GESTION DES UTILISATEURS UNIQUEMENT POUR LES ADMIN -->
{% if is_granted('ROLE_ADMIN') %}
<section class="card shadow-sm border-0 my-3">
    <div class="p-3">
        <h2 class="h5 fw-bold py-2">Gestion des utilisateurs</h2>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">#</th>
                        <th class="ps-4">Identifiant / Email</th>
                        <th class="ps-4">Nom</th>
                        <th class="ps-4">Prénom</th>
                        <th>Rôles</th>
                        <th>Statut</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">{{ user.id }}</div>
                            </td>
                            <td class="ps-4">
                                <div class="fw-bold">{{ user.email }}</div>
                            </td>
                            <td class="ps-4">
                                <div class="fw-bold">{{ user.name }}</div>
                            </td>
                            <td class="ps-4">
                                <div class="fw-bold">{{ user.firstname }}</div>
                            </td>
                            <td>
                                {% for role in user.roles %}
                                    {% if role == 'ROLE_ADMIN' %}
                                        <span class="badge bg-danger">Admin</span>
                                    {% elseif role == 'ROLE_USER' %}
                                        <span class="badge bg-info text-dark">Utilisateur</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ role }}</span>
                                    {% endif %}
                                {% endfor %}
                            </td>
                            <td>

                                <span class="badge {{ user.isVerified ? 'bg-success' : 'bg-warning' }}">
                                    {{ user.isVerified ? 'Vérifié' : 'En attente' }}
                                </span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">

                                    <twig:BootstrapButton type="warning" link="{{ path('app_user_update', { id: user.id }) }}" text="Modifier" outlined />

                                    {% if user != app.user and 'ROLE_ADMIN' not in user.roles %}
                                        <twig:BootstrapButton class="ms-2" 
                                            text="Supprimer"
                                            type="danger" 
                                            link="#" 
                                            outlined 
                                        /> 
                                    {% endif %}
                                </div>
                                <div>
                                    <twig:BootstrapButton class="mt-2"  type="primary" link="{{ path('app_user_roles', { id: user.id }) }}" text="Affecter des rôles" outlined />
                                </div>
                                
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">Aucun utilisateur trouvé.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</section>
{% endif %}
{% endblock %}